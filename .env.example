# KBrain Docker Compose Environment Variables
# Copy this file to .env and fill in your values

# RAGFlow (required for document indexing)
RAGFLOW_URL=...
RAGFLOW_API_KEY=...
RAGFLOW_DATASET_ID=...
RAGFLOW_WAIT_FOR_PARSING=true
RAGFLOW_MAX_WAIT=3000.0

# OpenAI
OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=gpt-5.2-2025-12-11
OPENAI_API_KEY=...

# XLSX Medication Processor (dla plików z tagiem 'xlsx_z_lekami')
XLSX_MEDICATION_SERVICE_URL=http://host/api/dosage/upload
