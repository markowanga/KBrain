# KBrain Backend Environment Variables

# Application
APP_NAME=KBrain API
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://kbrain:kbrain@localhost:5438/kbrain
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# CORS
CORS_ORIGINS=["http://localhost:5174", "http://localhost:3000"]

# Storage
STORAGE_BACKEND=local
STORAGE_ROOT=storage_data

# AWS S3 (if using S3 storage backend)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=

# Azure Blob (if using Azure storage backend)
# AZURE_STORAGE_ACCOUNT=
# AZURE_STORAGE_KEY=
# AZURE_STORAGE_CONTAINER=

# Upload limits
MAX_FILE_SIZE=104857600

# Document Processing
PROCESSING_ENABLED=true
PROCESSING_MAX_RETRIES=3
# PROCESSING_API_TOKEN=

# RabbitMQ
RABBITMQ_URL=amqp://admin:admin123@localhost:5672/
RABBITMQ_QUEUE_NAME=document_processing
RABBITMQ_PREFETCH_COUNT=10

# OpenAI (required for PDF/DOCX and image processing)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=gpt-5.2-2025-12-11

# XLSX Medication Processor (for files tagged 'xlsx_z_lekami')
# XLSX_MEDICATION_SERVICE_URL=http://localhost:8080

# RAGFlow (required for document indexing)
RAGFLOW_URL=http://localhost:9380
RAGFLOW_API_KEY=ragflow-...
RAGFLOW_DATASET_ID=your-dataset-id
RAGFLOW_WAIT_FOR_PARSING=true
RAGFLOW_MAX_WAIT=300.0
